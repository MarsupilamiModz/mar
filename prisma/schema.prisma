  createdAt DateTime         @default(now())

  @@index([programId])
}

model TranslationJob {
  id             String               @id @default(cuid())
  entityType     String
  entityId       String
  field          String
  sourceLocale   String
  targetLocale   String
  sourceText     String               @db.Text
  translatedText String?              @db.Text
  status         TranslationJobStatus @default(PENDING)
  error          String?
  approvedById   String?
  approvedBy     User?                @relation("TranslationApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([entityType, entityId])
  @@index([status, targetLocale])
}

model SnakeScore {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  username  String
  score     Int
  createdAt DateTime @default(now())

  @@index([score])
  @@index([createdAt])
}

model Achievement {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String?             @db.Text
  title       String?
  category    AchievementCategory
  rarity      AchievementRarity   @default(COMMON)
  icon        String?
  imageUrl    String?
  xpReward    Int                 @default(0)
  isHidden    Boolean             @default(false)
  isSeasonal  Boolean             @default(false)
  seasonStart DateTime?
  seasonEnd   DateTime?
  unlockRule  Json?
  translations Json?
  animated    Boolean             @default(false)
  glowEffect  Boolean             @default(true)
  sortOrder   Int                 @default(0)
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  userAchievements UserAchievement[]

  @@index([category, isActive])
  @@index([rarity])
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())
  isShowcased   Boolean     @default(false)
  showcaseOrder Int?
  grantedById   String?
  progress      Int         @default(100)

  @@unique([userId, achievementId])
  @@index([userId, isShowcased])
}

model UserProgress {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  xp        Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt
}

enum ShopProductCategory {
  CREDITS
  MEMBERSHIP
  MODS
  EXCLUSIVE
  BUNDLES
  ACCESS
  CUSTOM_SERVICES
}

enum ShopProductType {
  CREDIT_PACK
  MEMBERSHIP
  MOD
  EXCLUSIVE
  BUNDLE
  SUBSCRIPTION
  ACCESS
  CUSTOM
}

enum ShopPricingMode {
  FIXED
  VARIABLE
  STARTING_FROM
  QUOTE
  SUBSCRIPTION
  ONE_TIME
}

enum ShopProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  DISABLED
}

enum ShopFormFieldType {
  TEXT
  TEXTAREA
  DROPDOWN
  CHECKBOX
  RADIO
  DATE
  IMAGE_UPLOAD
  FILE_UPLOAD
}

enum ShopMediaType {
  COVER
  BANNER
  FEATURED
  GALLERY
  EXAMPLE
  VIDEO
}

model ShopProductTypeDefinition {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  iconKey     String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  isCustom    Boolean  @default(true)
  translations Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products ShopProduct[]

  @@index([isActive, sortOrder])
}

model ShopCategory {
  id           String         @id @default(cuid())
  slug         String         @unique
  name         String
  description  String?        @db.Text
  parentId     String?
  parent       ShopCategory?  @relation("ShopCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children     ShopCategory[] @relation("ShopCategoryTree")
  sortOrder    Int            @default(0)
  isActive     Boolean        @default(true)
  translations Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  products          ShopProduct[] @relation("ProductCategory")
  subcategoryProducts ShopProduct[] @relation("ProductSubcategory")

  @@index([parentId, sortOrder])
  @@index([isActive, sortOrder])
}

model ShopProduct {
  id               String              @id @default(cuid())
  slug             String              @unique
  name             String
  shortDescription String?             @db.Text
  description      String?             @db.Text
  category         ShopProductCategory @default(CUSTOM_SERVICES)
  productType      ShopProductType     @default(CUSTOM)
  customTypeId     String?
  customType       ShopProductTypeDefinition? @relation(fields: [customTypeId], references: [id], onDelete: SetNull)
  shopCategoryId   String?
  shopCategory     ShopCategory?       @relation("ProductCategory", fields: [shopCategoryId], references: [id], onDelete: SetNull)
  subcategoryId    String?
  subcategory      ShopCategory?       @relation("ProductSubcategory", fields: [subcategoryId], references: [id], onDelete: SetNull)
  tags             Json                @default("[]")
  status           ShopProductStatus   @default(ACTIVE)
  pricingMode      ShopPricingMode     @default(FIXED)
  creditPrice      Int                 @default(0)
  priceCents       Int                 @default(0)
  stripePriceId    String?
  creditsAmount    Int?
  modId            String?
  mod              Mod?                @relation(fields: [modId], references: [id], onDelete: SetNull)
  membershipPlanId String?
  membershipPlan   MembershipPlan?     @relation(fields: [membershipPlanId], references: [id], onDelete: SetNull)
  thumbnailUrl     String?
  coverImageUrl    String?
  bannerImageUrl   String?
  featuredImageUrl String?
  videoUrl         String?
  stock            Int?
  isFeatured       Boolean             @default(false)
  isActive         Boolean             @default(true)
  isArchived       Boolean             @default(false)
  visibility       String              @default("public")
  salePercent      Int                 @default(0)
  creatorShareBps  Int                 @default(0)
  partnerShareBps  Int                 @default(0)
  customFields     Json                @default("{}")
  sortOrder        Int                 @default(0)
  translations     Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  formFields ShopProductFormField[]
  media      ShopProductMedia[]
  purchases  ShopPurchase[]
  orders     CustomOrder[]

  @@index([isActive, isFeatured, sortOrder])
  @@index([status, isArchived])
  @@index([category])
  @@index([shopCategoryId])
  @@index([customTypeId])
}

model ShopProductFormField {
  id          String            @id @default(cuid())
  productId   String
  product     ShopProduct       @relation(fields: [productId], references: [id], onDelete: Cascade)
  fieldType   ShopFormFieldType
  label       String
  placeholder String?
  helpText    String?
  required    Boolean           @default(false)
  options     Json?
  validation  Json?
  sortOrder   Int               @default(0)

  @@index([productId, sortOrder])
}

model ShopProductMedia {
  id        String        @id @default(cuid())
  productId String
  product   ShopProduct   @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaType ShopMediaType @default(GALLERY)
  url       String
  alt       String?
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())

  @@index([productId, mediaType, sortOrder])
}

model ShopPurchase {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId       String
  product         ShopProduct  @relation(fields: [productId], references: [id])
  creditsSpent    Int          @default(0)
  priceCents      Int          @default(0)
  stripePaymentId String?
  formResponses   Json?
  customOrder     CustomOrder?
  createdAt       DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([productId])
  @@index([stripePaymentId])
}

model FileScanLog {
  id            String         @id @default(cuid())
  modVersionId  String?
  modVersion    ModVersion?    @relation(fields: [modVersionId], references: [id], onDelete: SetNull)
  modId         String?
  fileName      String
  fileSize      BigInt
  sha256        String
  status        FileScanStatus
  detections    Int            @default(0)
  totalEngines  Int            @default(0)
  provider      String         @default("virustotal")
  report        Json?
  blocked       Boolean        @default(false)
  createdAt     DateTime       @default(now())

  @@index([status, createdAt])
  @@index([sha256])
  @@index([modId])
}

model FileScan {
  id            String            @id @default(cuid())
  modVersionId  String?
  modVersion    ModVersion?       @relation(fields: [modVersionId], references: [id], onDelete: SetNull)
  fileKey       String
  fileName      String
  fileSize      BigInt
  sha256        String
  md5           String?
  vtScanId      String?
  vtPermalink   String?
  scannedAt     DateTime?
  status        FileScanStatus
  riskLevel     SecurityRiskLevel @default(NONE)
  riskScore     Int               @default(0)
  detections    Int               @default(0)
  totalEngines  Int               @default(0)
  engineResults Json?
  scanReport    Json?
  cachedUntil   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  reviews SecurityReview[]

  @@index([sha256])
  @@index([modVersionId])
  @@index([status, scannedAt])
  @@map("file_scans")
}

model SecurityReview {
  id           String     @id @default(cuid())
  modVersionId String
  modVersion   ModVersion @relation(fields: [modVersionId], references: [id], onDelete: Cascade)
  fileScanId   String?
  fileScan     FileScan?  @relation(fields: [fileScanId], references: [id], onDelete: SetNull)
  status       String
  approvedById String?
  approvedBy   User?      @relation("SecurityReviewer", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt   DateTime?
  reason       String?
  notes        String?    @db.Text
  isTrusted    Boolean    @default(false)
  createdAt    DateTime   @default(now())

  @@index([modVersionId])
  @@index([status])
  @@map("security_reviews")
}

model SecurityLog {
  id           String              @id @default(cuid())
  modVersionId String?
  modId        String?
  userId       String?
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  action       SecurityAuditAction
  ipHash       String?
  userAgent    String?             @db.VarChar(512)
  deviceInfo   String?
  metadata     Json?
  createdAt    DateTime            @default(now())

  @@index([action, createdAt])
  @@index([modVersionId])
  @@index([modId])
  @@index([userId])
  @@map("security_logs")
}

model TrustedFile {
  id           String     @id @default(cuid())
  modVersionId String     @unique
  modVersion   ModVersion @relation(fields: [modVersionId], references: [id], onDelete: Cascade)
  approvedById String
  approvedBy   User       @relation("TrustedFileApprover", fields: [approvedById], references: [id], onDelete: Cascade)
  approvedAt   DateTime   @default(now())
  reason       String?
  notes        String?    @db.Text

  @@map("trusted_files")
}

model TrustedCreator {
  id               String            @id @default(cuid())
  creatorProfileId String            @unique
  creatorProfile   CreatorProfile    @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  trustLevel       CreatorTrustLevel @default(NEW)
  approvedById     String?
  approvedBy       User?             @relation("TrustedCreatorApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt       DateTime?
  notes            String?           @db.Text
  priorityScan     Boolean           @default(false)
  fastTrack        Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([trustLevel])
  @@map("trusted_creators")
}

model ScanQueue {
  id           String          @id @default(cuid())
  modVersionId String?
  modVersion   ModVersion?     @relation(fields: [modVersionId], references: [id], onDelete: Cascade)
  modId        String?
  fileKey      String
  fileName     String
  fileSize     BigInt
  sha256       String?
  priority     Int             @default(0)
  status       ScanQueueStatus @default(PENDING)
  attempts     Int             @default(0)
  maxAttempts  Int             @default(5)
  lastError    String?         @db.Text
  vtAnalysisId String?
  scheduledAt  DateTime        @default(now())
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([status, priority, scheduledAt])
  @@index([modVersionId])
  @@map("scan_queue")
}

model ModCollection {
  id            String                     @id @default(cuid())
  slug          String                     @unique
  title         String
  description   String?                    @db.Text
  coverUrl      String?
  bannerUrl     String?
  visibility    CollectionVisibility       @default(PUBLIC)
  moderationStatus CollectionModerationStatus @default(APPROVED)
  adminNotes    String?                    @db.Text
  isFeatured    Boolean                    @default(false)
  sortOrder     Int                        @default(0)
  ownerId       String
  owner         User                       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  creatorId     String?
  creator       CreatorProfile?            @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  viewCount     Int                        @default(0)
  downloadCount Int                        @default(0)
  followerCount Int                        @default(0)
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt

  items     ModCollectionItem[]
  followers ModCollectionFollow[]

  @@index([visibility, isFeatured])
  @@index([moderationStatus, sortOrder])
  @@index([ownerId])
}

model ModCollectionItem {
  id           String        @id @default(cuid())
  collectionId String
  collection   ModCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  modId        String
  mod          Mod           @relation(fields: [modId], references: [id], onDelete: Cascade)
  sortOrder    Int           @default(0)
  note         String?

  @@unique([collectionId, modId])
  @@index([collectionId, sortOrder])
}

model ModCollectionFollow {
  id           String        @id @default(cuid())
  collectionId String
  collection   ModCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())

  @@unique([collectionId, userId])
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String
  scopes      String[]
  rateLimit   Int       @default(1000)
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([keyHash])
  @@index([isActive])
}

model CreatorApplication {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          ApplicationStatus @default(PENDING)
  displayName     String
  email           String
  discord         String?
  portfolioUrl    String?
  youtubeUrl      String?
  twitchUrl       String?
  tiktokUrl       String?
  instagramUrl    String?
  xUrl            String?
  websiteUrl      String?
  message         String?           @db.Text
  portfolioImages Json              @default("[]")
  sampleModUrls   Json              @default("[]")
  adminNotes      String?           @db.Text
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([userId])
}

model PartnerApplication {
  id                      String            @id @default(cuid())
  userId                  String
  user                    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status                  ApplicationStatus @default(PENDING)
  creatorName             String
  username                String?
  email                   String
  discord                 String?
  youtubeUrl              String?
  twitchUrl               String?
  tiktokUrl               String?
  instagramUrl            String?
  xUrl                    String?
  websiteUrl              String?
  audienceSize            String?
  country                 String?
  platforms               Json              @default("[]")
  promotionStrategy       String?           @db.Text
  whyPartner              String?           @db.Text
  socialLinks             Json              @default("{}")
  customResponses         Json              @default("{}")
  requiredChanges         String?           @db.Text
  statusHistory           Json              @default("[]")
  message                 String?           @db.Text
  adminNotes              String?           @db.Text
  assignedCreatorCode     String?
  assignedPartnerCode     String?
  assignedCommissionRuleId String?
  assignedCommissionRule  CommissionRule?   @relation(fields: [assignedCommissionRuleId], references: [id], onDelete: SetNull)
  reviewedById            String?
  reviewedAt              DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@index([status, createdAt])
  @@index([userId])
  @@index([assignedCommissionRuleId])
}

model StorageUploadSession {
  id             String              @id @default(cuid())
  userId         String
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose        String
  fileKey        String
  uploadId       String
  fileName       String
  fileSize       BigInt
  contentType    String
  status         UploadSessionStatus @default(IN_PROGRESS)
  modId          String?
  metadata       Json?
  completedParts Json                @default("[]")
  createdAt      DateTime            @default(now())
  expiresAt      DateTime

  @@index([userId, status])
  @@index([uploadId])
  @@index([createdAt])
}

model MediaFile {
  id           String          @id @default(cuid())
  fileName     String
  originalName String
  fileType     String
  mimeType     String
  fileSize     BigInt          @default(0)
  storagePath  String          @unique
  publicUrl    String
  entityType   MediaEntityType
  entityId     String?
  uploadedById String
  uploadedBy   User            @relation("MediaUploader", fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt    DateTime        @default(now())

  @@index([entityType, entityId])
  @@index([uploadedById])
  @@map("media_files")
}

enum TeamVisibility {
  PUBLIC
  INTERNAL
  HIDDEN
}

model TeamDepartment {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  description  String?      @db.Text
  sortOrder    Int          @default(0)
  isActive     Boolean      @default(true)
  translations Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  members TeamMember[]

  @@index([isActive, sortOrder])
}

model TeamMember {
  id           String          @id @default(cuid())
  name         String
  position     String
  description  String?         @db.Text
  email        String?
  avatarUrl    String?
  bannerUrl    String?
  discordUrl   String?
  youtubeUrl   String?
  twitchUrl    String?
  tiktokUrl    String?
  instagramUrl String?
  xUrl         String?
  websiteUrl   String?
  customLinks  Json?
  departmentId String?
  department   TeamDepartment? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  visibility   TeamVisibility  @default(PUBLIC)
  sortOrder    Int             @default(0)
  isActive     Boolean         @default(true)
  userId       String?         @unique
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([visibility, isActive, sortOrder])
  @@index([departmentId, sortOrder])
}
