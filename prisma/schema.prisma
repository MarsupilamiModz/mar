generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MODERATOR
  SUPPORT
  CREATOR
  PARTNER
  DESIGNER
  PREMIUM
  USER
}

enum MediaEntityType {
  MOD_SCREENSHOT
  MOD_MEDIA
  USER_AVATAR
  SOUND_PREVIEW
  SOUND_COVER
  CREATOR_BANNER
  PARTNER_LOGO
  GAME_ASSET
  COLLECTION_COVER
  OTHER
}

enum ModVisibility {
  PUBLIC
  UNLISTED
  PRIVATE
}

enum ModPricing {
  FREE
  PREMIUM
  PAID
}

enum ProductType {
  MOD
  SOUND
}

enum SoundAudioCategory {
  ENGINE_SOUNDS
  WEAPON_SOUNDS
  SIRENS
  UI_SOUNDS
  AMBIENT_SOUNDS
  RADIO_PACKS
  VOICE_PACKS
  EFFECTS
  MUSIC_PACKS
  CUSTOM_AUDIO
}

enum SoundPreviewType {
  FULL
  SECONDS_30
  SECONDS_60
  CUSTOM
}

enum ModStatus {
  DRAFT
  PENDING
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum FileScanStatus {
  PENDING
  SCANNING
  CLEAN
  APPROVED
  SUSPICIOUS
  MALWARE
  REJECTED
  MANUAL_REVIEW
  FAILED
}

enum SecurityRiskLevel {
  NONE
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ScanQueueStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum SecurityAuditAction {
  UPLOAD
  SCAN_STARTED
  SCAN_COMPLETED
  APPROVAL
  REJECTION
  DOWNLOAD
  RE_SCAN
  TRUST_MARKED
  REVIEW_REQUESTED
  SCAN_REMOVED
  BULK_APPROVE
  BULK_REJECT
}

enum CreatorTrustLevel {
  NEW
  VERIFIED
  TRUSTED
  ELITE
}

enum VersionChannel {
  STABLE
  BETA
  ARCHIVED
}

enum CollectionVisibility {
  PUBLIC
  PRIVATE
  FEATURED
}

enum CollectionModerationStatus {
  PENDING
  APPROVED
  REJECTED
  ARCHIVED
}

enum ApplicationStatus {
  PENDING
  UNDER_REVIEW
  NEEDS_CHANGES
  APPROVED
  REJECTED
}

enum UploadSessionStatus {
  IN_PROGRESS
  COMPLETED
  ABORTED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
}

enum LicenseStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  REVOKED
  PAUSED
}

enum CouponType {
  PERCENT
  FIXED
}

enum AffiliateCodeType {
  CREATOR
  AFFILIATE
  PUBLIC
  PRIVATE
}

enum SocialPlatform {
  YOUTUBE
  TWITCH
  TIKTOK
  INSTAGRAM
  TWITTER
  DISCORD
  WEBSITE
}

enum CommissionType {
  FIXED
  PERCENT
  RECURRING
}

enum CommissionSource {
  SUBSCRIPTION
  MOD_SALE
  CUSTOM_ORDER
  COUPON
  REFERRAL
  BONUS
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

enum AffiliateEventType {
  CLICK
  CONVERSION
  SUBSCRIPTION
  SIGNUP
}

enum PublisherLevel {
  UNVERIFIED
  VERIFIED
  TRUSTED
  ELITE
  OFFICIAL_PARTNER
}

enum OrderStatus {
  PENDING
  PAID
  QUOTED
  IN_REVIEW
  ACCEPTED
  ASSIGNED
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  REVISION_REQUESTED
  REVIEW
  COMPLETED
  DELIVERED
  CANCELED
  REFUNDED
}

enum TicketStatus {
  NEW
  OPEN
  PENDING
  IN_PROGRESS
  WAITING_FOR_USER
  WAITING_FOR_STAFF
  ESCALATED
  RESOLVED
  CLOSED
}

enum TicketDepartment {
  SUPPORT
  MODERATION
  CREATOR_MANAGEMENT
  PARTNER_MANAGEMENT
  BILLING
  TECHNICAL_SUPPORT
  ADMINISTRATION
}

enum TicketCategory {
  GENERAL_SUPPORT
  TECHNICAL_SUPPORT
  BILLING
  PREMIUM_ACCESS
  CREATOR_SUPPORT
  PARTNER_SUPPORT
  BUG_REPORT
  CUSTOM_ORDERS
  MOD_ISSUES
  ACCOUNT_SUPPORT
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
  CRITICAL
}

enum BannerDisplayType {
  SMALL
  FEATURED
  CUSTOM
}

enum BannerAlign {
  CENTER
  TOP
  BOTTOM
  LEFT
  RIGHT
}

enum NotificationType {
  MESSAGE
  TICKET_REPLY
  CREATOR_ANNOUNCEMENT
  PARTNER_ANNOUNCEMENT
  MOD_UPDATE
  ORDER_UPDATE
  PREMIUM_ACTIVATED
  PREMIUM_EXPIRING
  NEW_FOLLOWER
  COMMENT_REPLY
  MENTION
  SYSTEM
}

enum BillingType {
  ONE_TIME
  RECURRING
}

enum ExclusiveProgramType {
  CLOSED_ALPHA
  CLOSED_BETA
  INVITE_ONLY
}

enum ExclusiveApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLIST
}

enum TranslationJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  APPROVED
}

enum AdFormat {
  BANNER
  SIDEBAR
  POPUP
  NATIVE
  MOBILE
  FOOTER
  SPONSOR
}

enum AdProviderType {
  ADSENSE
  MICROSOFT
  NITROPAY
  EZOIC
  CUSTOM
  AFFILIATE
  DIRECT
}

enum AchievementRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum AchievementCategory {
  USER
  CREATOR
  PARTNER
  SEASONAL
  HIDDEN
}

enum CreatorRankTier {
  BRONZE
  SILVER
  GOLD
  DIAMOND
  ELITE
  LEGENDARY
}

enum LeaderboardMetric {
  DOWNLOADS
  REVENUE
  LIKES
  GROWTH
  ACTIVE
  REVIEWED
  TRENDING
  RATED
}

enum LeaderboardPeriod {
  DAILY
  WEEKLY
  MONTHLY
  ALL_TIME
}

enum MembershipTier {
  FREE
  PREMIUM_LITE
  PREMIUM
  PREMIUM_MAX
}

enum UserMembershipStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
  EXPIRED
}

enum SoundApprovalStatus {
  PENDING_REVIEW
  VIRUS_TOTAL_VERIFIED
  MANUALLY_APPROVED
  REVIEW_REQUIRED
  REJECTED
  CHANGES_REQUESTED
}

enum OrderPaymentStatus {
  UNPAID
  AWAITING_PAYMENT
  PAID
  REFUNDED
}

enum OrderPaymentMethod {
  STRIPE
  PAYPAL
  BANK_TRANSFER
  CREDITS
}

model User {
  id                String    @id @default(cuid())
  supabaseId        String    @unique
  email             String    @unique
  username          String    @unique
  displayName       String?
  avatarUrl         String?
  avatarOriginalUrl String?
  avatar64Url       String?
  avatar128Url      String?
  avatar256Url      String?
  bio               String?
  locale            String    @default("en")
  discordId         String?   @unique
  discordUsername   String?
  stripeCustomerId  String?   @unique
  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  isBanned          Boolean   @default(false)
  banReason         String?
  bannedAt          DateTime?
  banExpiresAt      DateTime?
  bannedById        String?
  bannedBy          User?     @relation("BanIssuer", fields: [bannedById], references: [id])
  isMuted           Boolean   @default(false)
  isSuspended       Boolean   @default(false)
  warningCount      Int       @default(0)
  moderationNote    String?   @db.Text
  deletedAt         DateTime?
  role              UserRole  @default(USER)
  permissionGroupId String?
  permissionGroup   PermissionGroup? @relation(fields: [permissionGroupId], references: [id], onDelete: SetNull)
  teamDepartment    String?
  teamBadge         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  bansIssued        User[]    @relation("BanIssuer")
  banRecords        UserBan[] @relation("BannedUser")
  bansPerformed     UserBan[] @relation("BanActor")
  ticketMessages    TicketMessage[]
  creatorProfile    CreatorProfile?
  partnerProfile    PartnerProfile?
  designerProfile   DesignerProfile?
  mods              Mod[]              @relation("ModAuthor")
  reviews           ModReview[]
  favorites         ModFavorite[]
  downloads         Download[]
  subscriptions     Subscription[]
  licenseKeys       LicenseKey[]       @relation("LicenseOwner")
  licenseKeysAssigned LicenseKey[]     @relation("LicenseAssignee")
  licenseActivations LicenseActivation[]
  couponRedemptions CouponRedemption[]
  customOrders      CustomOrder[]      @relation("OrderClient")
  assignedOrders    CustomOrder[]      @relation("OrderAssignee")
  orderMessages     OrderMessage[]
  orderActivities   OrderActivity[]    @relation("OrderActivityActor")
  orderDeliveries   OrderDelivery[]    @relation("OrderDeliveryUploader")
  notifications     Notification[]
  auditLogs         AuditLog[]         @relation("AuditActor")
  supportTickets    SupportTicket[]    @relation("TicketUser")
  assignedTickets   SupportTicket[]    @relation("TicketAssignee")
  watchedTickets    TicketWatcher[]    @relation("TicketWatcher")
  purchases         ModPurchase[]
  blogPosts         BlogPost[]
  ownedCoupons      Coupon[]           @relation("CouponOwner")
  affiliateEvents   AffiliateEvent[]   @relation("AffiliateOwner")
  membershipPurchases MembershipPurchase[]
  exclusiveApplications ExclusiveApplication[]
  exclusivePrograms   ExclusiveProgram[] @relation("ExclusiveAuthor")
  snakeScores         SnakeScore[]
  translationJobs     TranslationJob[] @relation("TranslationApprover")
  commissionEntries CommissionEntry[]
  payouts           Payout[]
  profileFollowers  ProfileFollow[]    @relation("Follower")
  profileFollowing  ProfileFollow[]    @relation("Following")
  creatorLicenses   LicenseKey[]       @relation("LicenseCreator")
  userAchievements  UserAchievement[]
  userProgress      UserProgress?
  userMembership    UserMembership?
  shopPurchases     ShopPurchase[]
  soundApprovals    SoundProfile[]         @relation("SoundApprover")
  soundUploads      SoundProfile[]         @relation("SoundUploader")
  moderationLogs    UserModerationLog[]    @relation("ModerationTarget")
  moderationActions UserModerationLog[]    @relation("ModerationActor")
  modCollections    ModCollection[]
  collectionFollows ModCollectionFollow[]
  apiKeys           ApiKey[]
  creatorApplications CreatorApplication[]
  partnerApplications PartnerApplication[]
  storageUploads    StorageUploadSession[]
  uploadedMedia     MediaFile[]            @relation("MediaUploader")
  securityReviews   SecurityReview[]       @relation("SecurityReviewer")
  trustedFiles      TrustedFile[]          @relation("TrustedFileApprover")
  trustedCreators   TrustedCreator[]       @relation("TrustedCreatorApprover")
  securityLogs      SecurityLog[]
  teamProfile       TeamMember?
  emailLogs         EmailLog[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([isBanned])
  @@index([banExpiresAt])
  @@index([deletedAt])
  @@index([createdAt])
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  role         UserRole
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
}

model Game {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  description     String?  @db.Text
  shortDescription String? @db.VarChar(300)
  coverUrl        String?
  bannerUrl       String?
  iconUrl         String?
  bannerDisplayType BannerDisplayType @default(FEATURED)
  bannerHeightPx  Int?
  bannerFocusX    Float             @default(50)
  bannerFocusY    Float             @default(50)
  bannerZoom      Float             @default(1)
  bannerAlign     BannerAlign       @default(CENTER)
  seoTitle        String?
  seoDescription  String?
  isFeatured      Boolean  @default(false)
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  categories GameCategory[]
  mods       Mod[]

  @@index([isActive, isFeatured])
  @@index([sortOrder])
}

model GameCategory {
  id          String  @id @default(cuid())
  gameId      String
  game        Game    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      GameCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children    GameCategory[] @relation("CategoryTree")
  slug        String
  name        String
  description String?
  sortOrder   Int     @default(0)
  isVisible   Boolean @default(true)

  mods Mod[]

  @@unique([gameId, slug])
  @@index([gameId, sortOrder])
  @@index([gameId, isVisible])
  @@index([parentId])
}

model CreatorProfile {
  id                  String         @id @default(cuid())
  userId              String         @unique
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug                String         @unique
  tagline             String?
  description         String?        @db.Text
  bannerUrl           String?
  website             String?
  creatorCode         String?        @unique
  couponCode          String?        @unique
  referralCode        String?        @unique
  level               PublisherLevel @default(UNVERIFIED)
  commissionRateBps   Int            @default(500)
  commissionOverrideBps Int?
  isVerified          Boolean        @default(false)
  isFeatured          Boolean        @default(false)
  isSuspended         Boolean        @default(false)
  isPublic            Boolean        @default(false)
  isHomepage          Boolean        @default(false)
  isTrending          Boolean        @default(false)
  sortOrder           Int            @default(0)
  totalDownloads      Int            @default(0)
  totalRevenueCents   Int            @default(0)
  totalSales          Int            @default(0)
  totalCouponUses     Int            @default(0)
  totalDiscountCents  Int            @default(0)
  totalClicks         Int            @default(0)
  totalConversions    Int            @default(0)
  followerCount       Int            @default(0)
  rankTier            CreatorRankTier @default(BRONZE)
  rankScore           Float          @default(0)
  leaderboardPinned   Boolean        @default(false)
  pinnedUntil         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  socialLinks SocialLink[]
  collections ModCollection[]
  trustRecord TrustedCreator?

  @@index([isVerified, isFeatured])
  @@index([isPublic, sortOrder])
  @@index([isHomepage, sortOrder])
  @@index([isTrending])
  @@index([level])
  @@index([creatorCode])
  @@index([rankTier, rankScore])
}

model PartnerProfile {
  id                  String         @id @default(cuid())
  userId              String         @unique
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug                String         @unique
  tagline             String?
  description         String?        @db.Text
  bannerUrl           String?
  logoUrl             String?
  website             String?
  affiliateCode       String?        @unique
  couponCode          String?        @unique
  referralCode        String?        @unique
  level               PublisherLevel @default(UNVERIFIED)
  commissionRateBps   Int            @default(1000)
  commissionOverrideBps Int?
  isVerified          Boolean        @default(false)
  isFeatured          Boolean        @default(false)
  isSuspended         Boolean        @default(false)
  isBanned            Boolean        @default(false)
  isPublic            Boolean        @default(false)
  isHomepage          Boolean        @default(false)
  sortOrder           Int            @default(0)
  totalClicks         Int            @default(0)
  totalConversions    Int            @default(0)
  totalRevenueCents   Int            @default(0)
  totalEarningsCents  Int            @default(0)
  totalCouponUses     Int            @default(0)
  totalDiscountCents  Int            @default(0)
  followerCount       Int            @default(0)
  discordInviteUrl    String?
  discordWidgetUrl    String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  socialLinks SocialLink[]

  @@index([isVerified, isFeatured])
  @@index([isPublic, sortOrder])
  @@index([level])
  @@index([affiliateCode])
}

model SocialLink {
  id               String         @id @default(cuid())
  creatorProfileId String?
  creatorProfile   CreatorProfile? @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  partnerProfileId String?
  partnerProfile   PartnerProfile? @relation(fields: [partnerProfileId], references: [id], onDelete: Cascade)
  platform         SocialPlatform
  url              String
  sortOrder        Int            @default(0)

  @@index([creatorProfileId])
  @@index([partnerProfileId])
}

model DesignerProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug           String   @unique
  specialty      String?
  portfolioUrl   String?
  avatarUrl      String?
  bannerUrl      String?
  isVerified     Boolean  @default(false)
  totalDownloads Int      @default(0)
  totalEarnings  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Mod {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  description     String        @db.Text
  shortDescription String?
  gameId          String
  game            Game          @relation(fields: [gameId], references: [id])
  categoryId      String?
  category        GameCategory? @relation(fields: [categoryId], references: [id])
  authorId        String
  author          User          @relation("ModAuthor", fields: [authorId], references: [id])
  visibility      ModVisibility @default(PUBLIC)
  productType     ProductType   @default(MOD)
  pricing         ModPricing    @default(FREE)
  status          ModStatus     @default(DRAFT)
  priceCents      Int?
  stripePriceId   String?
  downloadCount   Int           @default(0)
  favoriteCount   Int           @default(0)
  averageRating   Float         @default(0)
  reviewCount     Int           @default(0)
  isFeatured      Boolean       @default(false)
  supportedVersions String[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  publishedAt     DateTime?

  versions      ModVersion[]
  media         ModMedia[]
  screenshots   ModScreenshot[]
  videos        ModVideo[]
  tags          ModTag[]
  dependencies  ModDependency[] @relation("ModDeps")
  dependents    ModDependency[] @relation("ModDependents")
  reviews       ModReview[]
  favorites     ModFavorite[]
  downloads     Download[]
  changelog     ModChangelog[]
  purchases     ModPurchase[]
  licenseKeys   LicenseKey[]
  shopProducts  ShopProduct[]

  exclusivePrograms ExclusiveProgram[]

  collections ModCollectionItem[]
  soundProfile SoundProfile?
  soundPlays   SoundPlay[]

  @@index([status, visibility, downloadCount])
  @@index([gameId, status])
  @@index([isFeatured, status])
  @@index([authorId])
  @@index([publishedAt])
  @@index([productType, status])
}

model ModVersion {
  id          String         @id @default(cuid())
  modId       String
  mod         Mod            @relation(fields: [modId], references: [id], onDelete: Cascade)
  version     String
  changelog   String?        @db.Text
  fileKey     String
  fileSize    BigInt
  fileName    String
  gameVersion String?
  sha256      String?
  scanStatus  FileScanStatus @default(PENDING)
  scanReport  Json?
  scannedAt   DateTime?
  channel     VersionChannel @default(STABLE)
  isPrimary   Boolean        @default(false)
  isArchived  Boolean        @default(false)
  downloadCount Int          @default(0)
  createdAt   DateTime       @default(now())

  downloads        Download[]
  scanLogs         FileScanLog[]
  fileScans        FileScan[]
  securityReviews  SecurityReview[]
  trustedFile      TrustedFile?
  scanQueueItems   ScanQueue[]

  @@unique([modId, version])
  @@index([modId, isPrimary])
  @@index([scanStatus])
  @@index([scannedAt])
}

model SoundProfile {
  id                   String             @id @default(cuid())
  modId                String             @unique
  mod                  Mod                @relation(fields: [modId], references: [id], onDelete: Cascade)
  artist               String?
  audioCategory        SoundAudioCategory @default(CUSTOM_AUDIO)
  durationSeconds      Int?
  bpm                  Int?
  genre                String?
  previewFileKey       String?
  previewFileId        String?            @unique
  previewFileName      String?
  previewFileSize      BigInt?
  previewMimeType      String?
  previewBitrateKbps   Int?
  previewDurationSeconds Int?
  uploadedById         String?
  uploadedBy           User?              @relation("SoundUploader", fields: [uploadedById], references: [id], onDelete: SetNull)
  previewType          SoundPreviewType   @default(FULL)
  previewCustomSeconds Int?
  waveformPeaks        Json?
  coverImageKey        String?
  previewScanStatus    FileScanStatus     @default(PENDING)
  approvalStatus       SoundApprovalStatus @default(PENDING_REVIEW)
  approvedAt           DateTime?
  approvedById         String?
  approvedBy           User?              @relation("SoundApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  rejectionReason      String?            @db.Text
  reviewNotes          String?            @db.Text
  playCount            Int                @default(0)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([audioCategory])
  @@index([genre])
  @@index([approvalStatus])
  @@index([previewScanStatus])
  @@index([uploadedById])
  @@map("sound_profiles")
}

model SoundPlay {
  id        String   @id @default(cuid())
  modId     String
  mod       Mod      @relation(fields: [modId], references: [id], onDelete: Cascade)
  userId    String?
  ipHash    String?
  createdAt DateTime @default(now())

  @@index([modId, createdAt])
  @@index([userId])
  @@map("sound_plays")
}

enum ModMediaType {
  IMAGE
  YOUTUBE
}

model ModMedia {
  id             String       @id @default(cuid())
  modId          String
  mod            Mod          @relation(fields: [modId], references: [id], onDelete: Cascade)
  mediaType      ModMediaType
  imageUrl       String?
  videoUrl       String?
  youtubeVideoId String?
  orderIndex     Int          @default(0)
  isFeatured     Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([modId, orderIndex])
  @@index([modId, isFeatured])
  @@map("mod_media")
}

model ModScreenshot {
  id        String @id @default(cuid())
  modId     String
  mod       Mod    @relation(fields: [modId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int    @default(0)
}

model ModVideo {
  id        String @id @default(cuid())
  modId     String
  mod       Mod    @relation(fields: [modId], references: [id], onDelete: Cascade)
  url       String
  title     String?
  sortOrder Int    @default(0)
}

model ModTag {
  id    String @id @default(cuid())
  modId String
  mod   Mod    @relation(fields: [modId], references: [id], onDelete: Cascade)
  name  String

  @@unique([modId, name])
}

model ModDependency {
  id           String  @id @default(cuid())
  modId        String
  mod          Mod     @relation("ModDeps", fields: [modId], references: [id], onDelete: Cascade)
  dependencyId String
  dependency   Mod     @relation("ModDependents", fields: [dependencyId], references: [id], onDelete: Cascade)
  isRequired   Boolean @default(true)
  minVersion   String?
  notes        String?

  @@unique([modId, dependencyId])
}

model ModChangelog {
  id        String   @id @default(cuid())
  modId     String
  mod       Mod      @relation(fields: [modId], references: [id], onDelete: Cascade)
  version   String
  content   String   @db.Text
  createdAt DateTime @default(now())
}

model ModReview {
  id        String   @id @default(cuid())
  modId     String
  mod       Mod      @relation(fields: [modId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  title     String?
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([modId, userId])
}

model ModFavorite {
  id        String   @id @default(cuid())
  modId     String
