# App — production: https://www.marsupilami-modz.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MarsupilamiModz

# Email (Resend) — custom order notifications
RESEND_API_KEY=
EMAIL_FROM=MarsupilamiModz <orders@marsupilami-modz.com>
ADMIN_ORDER_EMAIL=support@marsupilami-modz.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Prisma - use Supabase connection pooler for production)
DATABASE_URL=
DIRECT_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Create one-time Stripe Prices for each plan and set stripePriceId in Admin → Memberships

# Storage provider: auto | r2 | supabase
STORAGE_PROVIDER=auto
# Optional public CDN base — REQUIRED for client-side image resolution in production
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_R2_PUBLIC_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=marsupilami-storage
# Marsupilami CDN public base URL (Cloudflare R2 custom domain)
R2_PUBLIC_URL=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_WEBHOOK_URL=
DISCORD_ROLE_PREMIUM=
DISCORD_ROLE_CREATOR=
DISCORD_ROLE_MODERATOR=

# Security
DOWNLOAD_SIGNING_SECRET=

# AI Localization (OpenAI)
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
