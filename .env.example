# App — production: https://www.xumari-modz.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=XumariModz

# Email — SMTP (Admin → Email Settings) or Resend fallback
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_ENCRYPTION=STARTTLS

# Email fallback providers (optional — also configurable in Admin → Email Settings)
SES_SMTP_HOST=
SES_SMTP_PORT=587
SES_SMTP_USER=
SES_SMTP_PASSWORD=
SES_SMTP_ENCRYPTION=STARTTLS
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_PASSWORD=
BREVO_SMTP_ENCRYPTION=STARTTLS

# Cloudflare Turnstile (anti-spam on registration)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Email (Resend fallback)
RESEND_API_KEY=
EMAIL_FROM=XumariModz <orders@xumari-modz.com>
ADMIN_ORDER_EMAIL=support@xumari-modz.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Prisma)
# Production: Supabase pooler on port 6543 with pgbouncer=true
# Example: postgresql://postgres.[ref]:[pass]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5
DATABASE_URL=
# Migrations only — direct connection on port 5432 (not the pooler)
DIRECT_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Create one-time Stripe Prices for each plan and set stripePriceId in Admin → Memberships

# Storage provider: auto | r2 | supabase
STORAGE_PROVIDER=auto
# Optional public CDN base — REQUIRED for client-side image resolution in production
NEXT_PUBLIC_CDN_URL=
NEXT_PUBLIC_R2_PUBLIC_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=xumari-storage
# Xumari CDN public base URL (Cloudflare R2 custom domain)
R2_PUBLIC_URL=

# Discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_WEBHOOK_URL=
DISCORD_ROLE_PREMIUM=
DISCORD_ROLE_CREATOR=
DISCORD_ROLE_MODERATOR=

# Security
DOWNLOAD_SIGNING_SECRET=

# AI Localization (OpenAI)
OPENAI_API_KEY=
OPENAI_TRANSLATION_MODEL=gpt-4o-mini
# Optional: DEEPL_API_KEY=, GOOGLE_TRANSLATE_API_KEY=
# Set TRANSLATION_REQUIRE_APPROVAL=true for manual review in Admin → Localization
TRANSLATION_REQUIRE_APPROVAL=
